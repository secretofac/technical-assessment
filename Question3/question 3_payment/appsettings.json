{
  "ConnectionStrings": {
    "Default": "${CONNECTION_STRING}"
  },
  "Database": {
    "MaxPoolSize": 100,
    "CommandTimeoutSeconds": 30
  },
  "Idempotency": {
    "RetentionHours": 24,
    "MaxKeyLength": 128
  },
  "RateLimiting": {
    "DefaultPermitLimit": 100,
    "WindowSizeSeconds": 60,
    "SegmentsPerWindow": 6,
    "MerchantOverrides": {
      "merchant-premium-001": 500,
      "merchant-restricted-999": 10
    }
  },
  "PaymentGateway": {
    "BaseUrl": "https://gateway.example.com",
    "TimeoutSeconds": 30
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  }
}
